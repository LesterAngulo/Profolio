---
interface Props {
  /** Colores de las manchas en formato "R, G, B". Por defecto usa el acento del sitio + dos tonos complementarios */
  colors?: [string, string, string];
  /** Duración de un ciclo de movimiento, en segundos. Más alto = más lento y sutil */
  speed?: number;
}

const {
  colors = ["20, 184, 166", "222, 133, 74", "139, 92, 246"],
  speed = 30,
} = Astro.props;

const style = `--color-a: ${colors[0]}; --color-b: ${colors[1]}; --color-c: ${colors[2]}; --aurora-speed: ${speed}s;`;
---

<div
  id="aurora-bg"
  class="fixed inset-0 -z-10 overflow-hidden pointer-events-none"
  style={style}
>
  <span class="blob blob-a"></span>
  <span class="blob blob-b"></span>
  <span class="blob blob-c"></span>
</div>

<style>
  .blob {
    position: absolute;
    width: 60vmax;
    height: 60vmax;
    border-radius: 50%;
    filter: blur(60px);
    will-change: transform;
  }

  .blob-a {
    top: -15%;
    left: -15%;
    background: radial-gradient(
      circle,
      rgba(var(--color-a), 0.18),
      transparent 70%
    );
    animation: float-a var(--aurora-speed) ease-in-out infinite;
  }

  .blob-b {
    bottom: -20%;
    right: -10%;
    background: radial-gradient(
      circle,
      rgba(var(--color-b), 0.15),
      transparent 70%
    );
    animation: float-b var(--aurora-speed) ease-in-out infinite;
    animation-delay: calc(var(--aurora-speed) * -0.33);
  }

  .blob-c {
    top: 25%;
    right: 15%;
    background: radial-gradient(
      circle,
      rgba(var(--color-c), 0.13),
      transparent 70%
    );
    animation: float-c var(--aurora-speed) ease-in-out infinite;
    animation-delay: calc(var(--aurora-speed) * -0.66);
  }

  :global(html.dark) .blob-a {
    background: radial-gradient(
      circle,
      rgba(var(--color-a), 0.28),
      transparent 70%
    );
  }
  :global(html.dark) .blob-b {
    background: radial-gradient(
      circle,
      rgba(var(--color-b), 0.22),
      transparent 70%
    );
  }
  :global(html.dark) .blob-c {
    background: radial-gradient(
      circle,
      rgba(var(--color-c), 0.2),
      transparent 70%
    );
  }

  @keyframes float-a {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(6%, 8%) scale(1.08);
    }
  }
  @keyframes float-b {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-8%, -5%) scale(1.05);
    }
  }
  @keyframes float-c {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-5%, 7%) scale(1.1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blob {
      animation: none;
    }
  }
</style>