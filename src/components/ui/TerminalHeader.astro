---
interface Props {
  title?: string;
  date?: string;
}

const { title, date } = Astro.props;
---

<div class="mb-4 pb-3 border-b border-gray-300 dark:border-gray-600">
  <div class="flex items-center gap-2">
    <div class="flex gap-2 shrink-0" role="img" aria-label="Window controls">
      <div class="w-3 h-3 rounded-full bg-red-500"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
      <div class="w-3 h-3 rounded-full bg-green-500"></div>
    </div>

    {
      title && (
        <span class="flex-1 truncate text-center text-lg font-bold text-primary px-2">
          {title}
        </span>
      )
    }

    <!-- Toolbar completa (oculta en mobile) -->
    <div
      class="hidden sm:flex items-center gap-3 text-muted shrink-0"
      aria-hidden="true"
    >
      <span class="text-[11px] font-semibold leading-none">Aa</span>

      <!-- checklist -->
      <svg
        viewBox="0 0 16 16"
        class="h-4 w-4"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
      >
        <circle cx="2" cy="3" r="0.6" fill="currentColor" stroke="none" />
        <line x1="5" y1="3" x2="14" y2="3"></line>
        <circle cx="2" cy="8" r="0.6" fill="currentColor" stroke="none" />
        <line x1="5" y1="8" x2="14" y2="8"></line>
        <circle cx="2" cy="13" r="0.6" fill="currentColor" stroke="none" />
        <line x1="5" y1="13" x2="14" y2="13"></line>
      </svg>

      <!-- tabla -->
      <svg
        viewBox="0 0 16 16"
        class="h-4 w-4"
        fill="none"
        stroke="currentColor"
        stroke-width="1.3"
      >
        <rect x="1.5" y="1.5" width="13" height="13" rx="1.5"></rect>
        <line x1="1.5" y1="6" x2="14.5" y2="6"></line>
        <line x1="1.5" y1="10.5" x2="14.5" y2="10.5"></line>
        <line x1="6" y1="1.5" x2="6" y2="14.5"></line>
        <line x1="10.5" y1="1.5" x2="10.5" y2="14.5"></line>
      </svg>

      <!-- enlace / adjunto -->
      <svg
        viewBox="0 0 16 16"
        class="h-4 w-4"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
      >
        <path d="M6.5 9.5l3-3a2.1 2.1 0 0 1 3 3l-2 2a2.1 2.1 0 0 1-3 0"
        ></path>
        <path d="M9.5 6.5l-3 3a2.1 2.1 0 0 1-3-3l2-2a2.1 2.1 0 0 1 3 0"
        ></path>
      </svg>

      <!-- imagen + chevron -->
      <span class="flex items-center">
        <svg
          viewBox="0 0 16 16"
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linejoin="round"
        >
          <rect x="1.5" y="4" width="13" height="9.5" rx="1.5"></rect>
          <path d="M4.5 4l1.2-1.8h4.6L11.5 4"></path>
          <circle cx="8" cy="8.7" r="2.2"></circle>
        </svg>
        <svg
          viewBox="0 0 10 10"
          class="h-2.5 w-2.5"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M2 3.5l3 3 3-3"></path>
        </svg>
      </span>

      <!-- overflow -->
      <svg
        viewBox="0 0 16 16"
        class="h-4 w-4"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M4 3l4 5-4 5"></path>
        <path d="M9 3l4 5-4 5"></path>
      </svg>
    </div>

    <!-- Versión mobile: solo overflow -->
    <div class="flex sm:hidden items-center text-muted shrink-0" aria-hidden="true">
      <svg
        viewBox="0 0 16 16"
        class="h-4 w-4"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M4 3l4 5-4 5"></path>
        <path d="M9 3l4 5-4 5"></path>
      </svg>
    </div>
  </div>

  {
    date && (
      <div class="mt-2.5 pt-2 border-t border-gray-200 dark:border-gray-700/60">
        <p class="text-center text-[11px] text-muted">{date}</p>
      </div>
    )
  }
</div>